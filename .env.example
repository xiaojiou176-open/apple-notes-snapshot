# Apple Notes Snapshot does not load a root `.env` file by default.
# The canonical runtime configuration lives in `config/notes_snapshot.env`.
#
# Copy the entries you need into `config/notes_snapshot.env` instead of editing
# this file directly. This template exists to document the main knobs in one
# place for open-source users.

# Export destination
# NOTES_SNAPSHOT_ROOT_DIR="$HOME/iCloudDrive/NotesSnapshots"

# Vendored upstream location
# NOTES_SNAPSHOT_DIR="$REPO_ROOT/vendor/notes-exporter"

# Runtime paths
# NOTES_SNAPSHOT_LOG_DIR="$REPO_ROOT/.runtime-cache/logs/apple-notes-snapshot"
# NOTES_SNAPSHOT_STATE_DIR="$REPO_ROOT/.runtime-cache/cache/apple-notes-snapshot/state"
# NOTES_SNAPSHOT_LOCK_DIR="$REPO_ROOT/.runtime-cache/cache/apple-notes-snapshot/lock/mkdir"

# Scheduling
# NOTES_SNAPSHOT_INTERVAL_MINUTES="30"
# NOTES_SNAPSHOT_CALENDAR_MINUTES="0,30"

# Log health pattern
# Default also catches the two launchd/runtime regressions this wrapper hardens:
# missing `python` on PATH and broken `export_notes.scpt` resolution.
# NOTES_SNAPSHOT_LOG_HEALTH_PATTERN="(ERROR|Error|FAIL|Failed|Traceback|Exception|command not found: python|export_notes\\.scpt: No such file or directory)"

# Vendor provenance contract
# - Prefer an immutable tag or commit SHA over a moving branch name.
# - Set NOTES_SNAPSHOT_VENDOR_URL and NOTES_SNAPSHOT_VENDOR_REF together when
#   you want a reviewable vendor refresh.
# - A valid `./notesctl update-vendor` run should regenerate VENDOR_INFO with
#   non-empty source/ref/commit provenance.

# Vendor source
# NOTES_SNAPSHOT_VENDOR_URL="https://github.com/storizzi/notes-exporter.git"
# Vendor ref (requested tag / branch / commit)
# NOTES_SNAPSHOT_VENDOR_REF="v1.3.0"
# Optional patch directory for local overlay patches
# NOTES_SNAPSHOT_VENDOR_PATCH_DIR="$REPO_ROOT/vendor_patches"

# Web UI
# Default is off. Enable it explicitly only when you want the local Web UI
# launchd service and have set a token first.
# NOTES_SNAPSHOT_WEB_ENABLE="1"
# NOTES_SNAPSHOT_WEB_HOST="127.0.0.1"
# NOTES_SNAPSHOT_WEB_PORT="8787"
# NOTES_SNAPSHOT_WEB_REQUIRE_TOKEN="1"
# NOTES_SNAPSHOT_WEB_TOKEN=""

# Do not put live tokens in tracked files. Copy needed values into
# `config/notes_snapshot.env`, which is the runtime-owned config surface.
