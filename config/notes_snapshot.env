# Environment overrides for scripts/core/notes_snapshot_wrapper.zsh
# Use ASCII-only content. Values are loaded via 'source'.

# Where exported snapshots are written
# NOTES_SNAPSHOT_ROOT_DIR="$HOME/iCloudDrive/NotesSnapshots"

# Where notes-exporter repo lives
# NOTES_SNAPSHOT_DIR="$REPO_ROOT/vendor/notes-exporter"

# Where logs are written
# NOTES_SNAPSHOT_LOG_DIR="$REPO_ROOT/.runtime-cache/logs/apple-notes-snapshot"

# Lock directory (prevents overlapping runs)
# NOTES_SNAPSHOT_LOCK_DIR="$REPO_ROOT/.runtime-cache/cache/apple-notes-snapshot/lock/mkdir"

# Lock file for flock (auto-releases on crash). Used when flock is available.
# NOTES_SNAPSHOT_LOCK_FILE="$REPO_ROOT/.runtime-cache/cache/apple-notes-snapshot/lock/flock.lock"

# State directory (run metadata for status/health checks)
# NOTES_SNAPSHOT_STATE_DIR="$REPO_ROOT/.runtime-cache/cache/apple-notes-snapshot/state"

# Repo-local disposable/runtime roots stay under .runtime-cache/.
# These are rebuildable maintainer surfaces, not exported snapshot data.
# NOTES_SNAPSHOT_RUNTIME_ROOT="$REPO_ROOT/.runtime-cache"
# NOTES_SNAPSHOT_TEMP_DIR="$REPO_ROOT/.runtime-cache/temp"
# NOTES_SNAPSHOT_PYTHONPYCACHEPREFIX="$REPO_ROOT/.runtime-cache/pycache"
# NOTES_SNAPSHOT_PYTEST_CACHE_DIR="$REPO_ROOT/.runtime-cache/pytest"
# NOTES_SNAPSHOT_COVERAGE_FILE="$REPO_ROOT/.runtime-cache/coverage/.coverage"

# External repo-owned cache/runtime residue lives under the current machine
# cache root selected by XDG_CACHE_HOME or the platform cache-home default.
# Automatic janitor hooks only touch this repo-owned root, never shared tool caches.
# NOTES_SNAPSHOT_EXTERNAL_CACHE_ROOT="<external-cache-root>"
# NOTES_SNAPSHOT_EXTERNAL_CACHE_TTL_HOURS="72"
# NOTES_SNAPSHOT_EXTERNAL_CACHE_MAX_BYTES="2147483648"
# NOTES_SNAPSHOT_BROWSER_CLONE_TTL_HOURS="24"
# NOTES_SNAPSHOT_RUNTIME_AUTO_CLEAN="1"
# NOTES_SNAPSHOT_VENDOR_RUNTIME_ROOT="<external-cache-root>/vendor-runtime/current"
# NOTES_SNAPSHOT_BROWSER_ROOT="<external-cache-root>/browser"
# Persistent isolated browser root. This repo keeps its own Chrome user-data dir here
# instead of sharing the default Chrome user-data root.
# NOTES_SNAPSHOT_CHROME_USER_DATA_DIR="<external-cache-root>/browser/chrome-user-data"
# NOTES_SNAPSHOT_BROWSER_TEMP_ROOT="<external-cache-root>/browser/tmp"
# Back-compat alias for the disposable browser temp subtree only.
# NOTES_SNAPSHOT_BROWSER_CACHE_ROOT="<external-cache-root>/browser/tmp"

# Browser automation contract: isolated real Chrome root, single instance, CDP attach-first,
# and no bundled Chromium fallback.
# NOTES_SNAPSHOT_BROWSER_PROVIDER="chrome"
# NOTES_SNAPSHOT_CHROME_PROFILE_NAME="apple-notes-snapshot"
# NOTES_SNAPSHOT_CHROME_PROFILE_DIR="Profile 1"
# NOTES_SNAPSHOT_CHROME_CHANNEL="chrome"
# NOTES_SNAPSHOT_CHROME_CDP_HOST="127.0.0.1"
# NOTES_SNAPSHOT_CHROME_CDP_PORT="9337"

# Default schedule interval in minutes (launchd)
# NOTES_SNAPSHOT_INTERVAL_MINUTES="30"

# Default vendor ref (tag/branch/commit). Used when no --ref is provided.
# NOTES_SNAPSHOT_VENDOR_REF="v1.3.0"

# Vendor source repo (override to use your fork)
# NOTES_SNAPSHOT_VENDOR_URL="https://github.com/storizzi/notes-exporter.git"

# Optional patch directory for vendor customization (applied in order)
# NOTES_SNAPSHOT_VENDOR_PATCH_DIR="$REPO_ROOT/vendor_patches"

# Consider export stale if last success is older than this (seconds)
# NOTES_SNAPSHOT_STALE_THRESHOLD_SEC="7200"

# Optional timeout for a single run (seconds). If empty, no timeout.
# NOTES_SNAPSHOT_TIMEOUT_SEC="1800"

# Max log size in bytes before rotation
# NOTES_SNAPSHOT_LOG_MAX_BYTES="5242880"

# Number of rotated backups to keep
# NOTES_SNAPSHOT_LOG_BACKUPS="5"

# Log rotation mode:
# - copytruncate (default): copy to .1 then truncate original (safe for launchd)
# - rename: rename to .1 and create a new file
# NOTES_SNAPSHOT_LOG_ROTATE_MODE="copytruncate"
# Write structured JSONL log lines to logs/structured.jsonl (1/0)
# NOTES_SNAPSHOT_LOG_JSONL="0"

# Write state files in JSON/summary formats (1 = yes, 0 = no)
# state.json is the canonical run record; other formats are derived.
# NOTES_SNAPSHOT_WRITE_STATE_JSON="1"
# NOTES_SNAPSHOT_WRITE_SUMMARY="1"

# Tail lines for logs_follow and status --verbose
# NOTES_SNAPSHOT_TAIL_LINES="200"

# Regex pattern used by `notesctl log-health`
# Default also catches the two launchd/runtime regressions this wrapper hardens:
# missing `python` on PATH and broken `export_notes.scpt` resolution.
# NOTES_SNAPSHOT_LOG_HEALTH_PATTERN="(ERROR|Error|FAIL|Failed|Traceback|Exception|command not found: python|export_notes\\.scpt: No such file or directory)"

# Preferred python binary (e.g. python3, /opt/homebrew/bin/python3)
# NOTES_SNAPSHOT_PYTHON_BIN=""

# Web UI host/port and command timeout (seconds)
# NOTES_SNAPSHOT_WEB_HOST="127.0.0.1"
# NOTES_SNAPSHOT_WEB_PORT="8787"
# NOTES_SNAPSHOT_WEB_CMD_TIMEOUT_SEC="10"
# NOTES_SNAPSHOT_WEB_ENABLE="0"
# Require token for all API calls (1/0). Default is 1 for safety.
# NOTES_SNAPSHOT_WEB_REQUIRE_TOKEN="1"
# Require token even for static Web UI assets (1/0). Default is 0.
# NOTES_SNAPSHOT_WEB_REQUIRE_TOKEN_FOR_STATIC="0"
# Web UI readonly mode (blocks POST actions).
# NOTES_SNAPSHOT_WEB_READONLY="0"
# Max tail lines for Web UI log/metrics endpoints.
# NOTES_SNAPSHOT_WEB_MAX_TAIL_LINES="2000"
# Allow Web UI to bind non-loopback (dangerous; requires token)
# NOTES_SNAPSHOT_WEB_ALLOW_REMOTE="0"
# Optional allowlist for client IPs (CSV of IP/CIDR). Empty = allow all.
# NOTES_SNAPSHOT_WEB_ALLOW_IPS="127.0.0.1,::1"
# Token required when binding to non-loopback (recommend long random string)
# NOTES_SNAPSHOT_WEB_TOKEN=""
# Optional scopes for the token (CSV). Empty or "all" = full access.
# NOTES_SNAPSHOT_WEB_TOKEN_SCOPES="read,run,install,vendor,logs,system"
# Optional allowlist of actions (CSV). Empty or "all" = allow all actions.
# NOTES_SNAPSHOT_WEB_ACTIONS_ALLOW="run,verify,logs"
# Optional API rate limiting window (seconds) + max requests per window.
# NOTES_SNAPSHOT_WEB_RATE_LIMIT_WINDOW_SEC="60"
# NOTES_SNAPSHOT_WEB_RATE_LIMIT_MAX="120"
# Optional action cooldowns (CSV action=sec). Empty = defaults (run=60, install=60, update-vendor=300). Use "off" to disable.
# NOTES_SNAPSHOT_WEB_ACTION_COOLDOWNS="run=60,install=60,update-vendor=300"
# Optional override path to notesctl (useful for testing)
# NOTES_SNAPSHOT_WEB_NOTESCTL=""

# AI Diagnose sidecar (opt-in, advisory-only, and note-content free by default)
# v1 routes model calls through a local Switchyard runtime instead of
# snapshot-owned provider integrations.
# NOTES_SNAPSHOT_AI_ENABLE="0"
# Current best-supported BYOK path in this repo: gemini via Switchyard.
# Set this to the upstream provider id that your local Switchyard runtime should use.
# NOTES_SNAPSHOT_AI_PROVIDER=""
# NOTES_SNAPSHOT_AI_MODEL=""
# Optional local Switchyard service root or invoke URL override.
# Examples:
# - Service root: http://127.0.0.1:4010
# - Explicit invoke URL: http://127.0.0.1:4010/v1/runtime/invoke
# Provider credentials stay on the Switchyard side, not in Apple Notes Snapshot.
# The Switchyard service itself must already be running with a provider
# credential name that it recognizes. For the current Gemini BYOK path, that
# means one of: SWITCHYARD_GEMINI_API_KEY, GEMINI_API_KEY, or GOOGLE_API_KEY.
# NOTES_SNAPSHOT_AI_BASE_URL="http://127.0.0.1:4010"
# Timeout for provider calls in seconds
# NOTES_SNAPSHOT_AI_TIMEOUT_SEC="20"
# Upper bound for generated diagnostic tokens
# NOTES_SNAPSHOT_AI_MAX_OUTPUT_TOKENS="700"
# Recent-run tail size to include in AI Diagnose summaries
# Phase 2 still only summarizes structured operational state and recent-run metadata.
# NOTES_SNAPSHOT_AI_DIAGNOSE_TAIL="5"
# Current v1 behavior keeps note content out of scope even if this is set to 1.
# Reserve this flag for future, more sensitive AI surfaces.
# NOTES_SNAPSHOT_AI_ALLOW_NOTE_CONTENT="0"
# Optional override path to notesctl for testing the AI sidecar
# NOTES_SNAPSHOT_AI_NOTESCTL=""

# MCP provider (stdio-first, read-only-first)
# Optional override path to notesctl for testing
# NOTES_SNAPSHOT_MCP_NOTESCTL=""
# Default recent-run tail for MCP tools/resources that summarize runs
# NOTES_SNAPSHOT_MCP_DEFAULT_TAIL="5"

# Optional launchd label overrides (useful for tests / multiple instances)
# NOTES_SNAPSHOT_LAUNCHD_LABEL="local.apple-notes-snapshot.custom"
# NOTES_SNAPSHOT_LAUNCHD_WEB_LABEL="local.apple-notes-snapshot.custom.webui"

# Prefer state.json over env files when reading state (1/0)
# NOTES_SNAPSHOT_PREFER_STATE_JSON="1"

# Lock TTL in seconds for mkdir fallback (0 = disabled)
# NOTES_SNAPSHOT_LOCK_TTL_SEC="0"

# Optional: mark trigger source for metrics/state (e.g. manual/web/launchd)
# NOTES_SNAPSHOT_TRIGGER_SOURCE=""

# Extra arguments passed to exportnotes.zsh (split on whitespace)
# NOTES_SNAPSHOT_ARGS="--convert-markdown true"

# Pipeline mode: run image extraction/markdown conversion while AppleScript is exporting.
# NOTES_EXPORT_PIPELINE="false"
# NOTES_EXPORT_PIPELINE_INTERVAL_SEC="5"
# NOTES_EXPORT_PIPELINE_STABLE_SEC="2"
# NOTES_EXPORT_PIPELINE_MAX_SEC="7200"
# NOTES_EXPORT_PIPELINE_MAX_ERROR_COUNT="5"
# NOTES_EXPORT_FAST_IMAGE_SCAN="false"
# NOTES_EXPORT_PIPELINE_MAX_IDLE_ROUNDS="0"
# NOTES_EXPORT_PIPELINE_WATCH_MODE="auto"
# NOTES_EXPORT_PIPELINE_DEBOUNCE_SEC="1.0"
# NOTES_EXPORT_PIPELINE_WATCH_PATHS=""
# NOTES_EXPORT_PIPELINE_WATCH_MODE uses watchdog when available; auto falls back to poll.
# NOTES_EXPORT_PIPELINE_EXIT_REASON_FILE=""

# launchd calendar schedule: run every hour at these minutes (comma-separated, e.g. "0,30")
# NOTES_SNAPSHOT_CALENDAR_MINUTES="0,30"

# Optional launchd event triggers (comma-separated absolute paths)
# NOTES_SNAPSHOT_LAUNCHD_WATCH_PATHS=""
# NOTES_SNAPSHOT_LAUNCHD_QUEUE_DIRS=""

# Throttle interval (seconds) to limit rapid re-triggers from WatchPaths/QueueDirectories
# NOTES_SNAPSHOT_LAUNCHD_THROTTLE_SEC="60"
# Recommended when WatchPaths/QueueDirectories are enabled.
